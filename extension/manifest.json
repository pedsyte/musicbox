{
  "manifest_version": 3,
  "name": "MusicBox Player",
  "version": "1.0.0",
  "description": "Мини-плеер для MusicBox — слушай музыку без открытой вкладки",
  "permissions": ["storage", "offscreen"],
  "host_permissions": ["https://musicbox.gornich.fun/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MusicBox Player"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
